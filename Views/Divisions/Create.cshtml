@model SistemaCE.Models.Division

@{
    ViewData["Title"] = "Crear División";
}
<link rel="stylesheet" href="~/css/create_globla.css" />

<div class="page-container">

    <div class="card-form">

        <div class="title">Crear División</div>
        <div class="subtitle">Registra una nueva división en el sistema</div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Nombre">Nombre de la División</label>
                <input asp-for="Nombre" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Nomenclatura">Nomenclatura</label>
                <input asp-for="Nomenclatura" />
                <span asp-validation-for="Nomenclatura" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary">Guardar</button>

        </form>

        <a asp-action="Index" class="back-link">← Volver al listado</a>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
