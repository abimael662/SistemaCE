@model SistemaCE.Models.Estudiante

@{
    ViewData["Title"] = "Editar Administrativo";
}

<link rel="stylesheet" href="~/css/edit_global.css" />
<div class="page-container">

    <div class="card-form">

        <div class="title">Editar Administrativo</div>
        <div class="subtitle">Modifica la información del registro</div>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdEstudiante" />

            <div class="form-group">
                <label asp-for="IdGrupo" class="control-label"></label>
                <select asp-for="IdGrupo" class="form-control" asp-items="ViewBag.IdGrupo"></select>
                <span asp-validation-for="IdGrupo" class="text-danger"></span>
            </div>

            @* <div class="form-group">
                <label>Empleado asignado</label>
                <select asp-for="NumeroEmpleado"
                        class="form-control"
                        asp-items="ViewBag.NumeroEmpleado">
                </select>
                <span asp-validation-for="NumeroEmpleado" class="text-danger"></span>
            </div> *@

            <div class="form-group">
                <label asp-for="Matricula" class="control-label"></label>
                <input asp-for="Matricula" class="form-control" />
                <span asp-validation-for="Matricula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaIngreso" class="control-label"></label>
                <input asp-for="FechaIngreso" class="form-control" />
                <span asp-validation-for="FechaIngreso" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Estatus" class="control-label"></label>
                <input asp-for="Estatus" class="form-control" />
                <span asp-validation-for="Estatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>

        </form>

        <a asp-action="Index" class="back-link">← Volver al listado</a>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}