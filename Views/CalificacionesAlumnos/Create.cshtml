@model SistemaCE.Models.CalificacionAlumno

@{
    ViewData["Title"] = "Create";
}

<div class="p-6">

    <!-- TÍTULO -->
    <h1 class="text-3xl font-bold mb-6">Captura de Calificaciones</h1>

    <!-- CARD -->
    <div class="bg-white shadow-xl rounded-2xl p-6 w-full max-w-3xl">

        <h2 class="text-xl font-semibold mb-4 border-b pb-2">
            Nueva Calificación
        </h2>

        <form asp-action="Create" class="space-y-4">

            <div asp-validation-summary="ModelOnly" class="text-red-500"></div>

            <!-- SELECTS -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Estudiante
                    </label>
                    <select asp-for="IdEstudiante"
                            class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                            asp-items="ViewBag.IdEstudiante">
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Materia
                    </label>
                    <select asp-for="IdMateria"
                            class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                            asp-items="ViewBag.IdMateria">
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Grupo
                    </label>
                    <select asp-for="IdGrupo"
                            class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none"
                            asp-items="ViewBag.IdGrupo">
                    </select>
                </div>

            </div>

            <!-- PARCIALES -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 pt-4 border-t">

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Parcial 1
                    </label>
                    <input asp-for="Parcial1"
                           class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Parcial 2
                    </label>
                    <input asp-for="Parcial2"
                           class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700">
                        Parcial 3
                    </label>
                    <input asp-for="Parcial3"
                           class="mt-1 w-full rounded-lg border-gray-300 focus:ring-2 focus:ring-blue-500 focus:outline-none" />
                </div>

            </div>

            <!-- PROMEDIO -->
            <div class="pt-4 border-t">
                <label class="block text-sm font-medium text-gray-700">
                    Promedio Final
                </label>
                <input asp-for="PromedioFinal"
                       class="mt-1 w-full rounded-lg border-gray-300 bg-gray-100"
                       readonly />
            </div>

            <!-- BOTONES -->
            <div class="flex justify-between items-center pt-4">

                <a asp-action="Index"
                   class="text-gray-600 hover:underline">
                    ← Volver
                </a>

                <button type="submit"
                        class="bg-blue-600 text-white px-6 py-2 rounded-xl shadow hover:bg-blue-700 transition">
                    Guardar
                </button>

            </div>

        </form>
    </div>
</div>