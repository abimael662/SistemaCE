@model IEnumerable<SistemaCE.Models.Docente>

@{
    ViewData["Title"] = "Docentes";
}

<link rel="stylesheet" href="~/css/index_global.css" />

<div class="page-container">

    <div class="header">
        <h1>Docentes</h1>

        <a asp-action="Create" class="btn-create">
            + Nuevo registro
        </a>
    </div>

    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Cédula Profesional</th>
                    <th>RFC</th>
                    <th>Sueldo</th>
                    <th>Persona</th>
                    <th>Empleado</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CedulaProfesional</td>
                        <td>@item.Rfc</td>

                        <td>
                            @string.Format(System.Globalization.CultureInfo.GetCultureInfo("es-MX"), "{0:C}", item.Sueldo)
                        </td>

                        <td>
                            @string.Join(" ",
                                item.IdDocenteNavigation?.Nombre ?? "",
                                item.IdDocenteNavigation?.ApellidoPaterno ?? "",
                                item.IdDocenteNavigation?.ApellidoMaterno ?? ""
                            )
                        </td>

                        <td>
                            @item.NumeroEmpleadoNavigation?.TipoEmpleado
                        </td>

                        <td class="actions">
                            <a asp-action="Edit" asp-route-id="@item.IdDocente">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.IdDocente">Ver</a>
                            <a asp-action="Delete" asp-route-id="@item.IdDocente">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>