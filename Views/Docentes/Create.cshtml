@model SistemaCE.Models.Docente

@{
    ViewData["Title"] = "Crear Docente";
}

<link rel="stylesheet" href="~/css/create_globla.css" />

<div class="page-container">

    <div class="card-form">

        <div class="title">Crear Docente</div>
        <div class="subtitle">Registra un nuevo docente en el sistema</div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label>Persona</label>
                <select asp-for="IdDocente"
                        class="form-control"
                        asp-items="ViewBag.IdDocente">
                    <option value="">Seleccione una persona</option>
                </select>
                <span asp-validation-for="IdDocente" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CedulaProfesional"></label>
                <input asp-for="CedulaProfesional" />
                <span asp-validation-for="CedulaProfesional" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Rfc"></label>
                <input asp-for="Rfc" />
                <span asp-validation-for="Rfc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Sueldo"></label>
                <input asp-for="Sueldo" type="number" step="0.01" />
                <span asp-validation-for="Sueldo" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary">Guardar</button>

        </form>

        <a asp-action="Index" class="back-link">← Volver al listado</a>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}