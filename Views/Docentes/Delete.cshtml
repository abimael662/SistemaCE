@model SistemaCE.Models.Docente

@{
    ViewData["Title"] = "Eliminar Docente";
}

<link rel="stylesheet" href="~/css/delete_global.css" />

<div class="page-container">

    <div class="card-delete">

        <div class="title">Eliminar Docente</div>
        <div class="subtitle">Esta acción no se puede deshacer</div>

        <div class="warning-box">
            ⚠️ ¿Estás seguro de eliminar este registro?
        </div>

        <div class="grid">

            <div class="item">
                <div class="label">Cédula Profesional</div>
                <div class="value">@Model.CedulaProfesional</div>
            </div>

            <div class="item">
                <div class="label">RFC</div>
                <div class="value">@Model.Rfc</div>
            </div>

            <div class="item">
                <div class="label">Sueldo</div>
                <div class="value">@Model.Sueldo</div>
            </div>

            <div class="item">
                <div class="label">Persona</div>
                <div class="value">
                    @Model.IdDocenteNavigation?.Nombre
                    @Model.IdDocenteNavigation?.ApellidoPaterno
                    @Model.IdDocenteNavigation?.ApellidoMaterno
                </div>
            </div>

            <div class="item">
                <div class="label">Empleado</div>
                <div class="value">
                    @Model.NumeroEmpleadoNavigation?.TipoEmpleado
                </div>
            </div>

        </div>

        <form asp-action="Delete" class="actions">
            <input type="hidden" asp-for="IdDocente" />

            <a asp-action="Index" class="btn btn-back">← Cancelar</a>
            <input type="submit" value="Eliminar" class="btn btn-delete" />
        </form>

    </div>

</div>