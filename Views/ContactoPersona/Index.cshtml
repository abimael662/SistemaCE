@model IEnumerable<SistemaCE.Models.ContactoPersona>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Dato)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdPersonaNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TipoComunicacionNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Dato)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdPersonaNavigation.IdPersona)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TipoComunicacionNavigation.IdTipoComunicacion)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdContacto">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdContacto">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdContacto">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
