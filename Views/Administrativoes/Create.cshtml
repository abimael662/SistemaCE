@model SistemaCE.Models.Administrativo

@{
    ViewData["Title"] = "Crear Administrativo";
}
<link rel="stylesheet" href="~/css/create_globla.css" />

<div class="page-container">

    <div class="card-form">

        <div class="title">Crear Administrativo</div>
        <div class="subtitle">Registra un nuevo administrativo en el sistema</div>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="IdAdministrativo">Usuario</label>
                <select asp-for="IdAdministrativo" class="form-control" asp-items="ViewBag.IdAdministrativo"></select>
            </div>

            <div class="form-group">
                <label asp-for="Departamento">Departamento</label>
                <input asp-for="Departamento" />
                <span asp-validation-for="Departamento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Puesto">Puesto</label>
                <input asp-for="Puesto" />
                <span asp-validation-for="Puesto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Rfc">RFC</label>
                <input asp-for="Rfc" />
                <span asp-validation-for="Rfc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Sueldo">Sueldo</label>
                <input asp-for="Sueldo" />
                <span asp-validation-for="Sueldo" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary">Guardar</button>

        </form>

        <a asp-action="Index" class="back-link">← Volver al listado</a>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
