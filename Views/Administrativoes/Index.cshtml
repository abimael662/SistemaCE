@model IEnumerable<SistemaCE.Models.Administrativo>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Departamento)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Puesto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Rfc)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Sueldo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdAdministrativoNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NumeroEmpleadoNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Departamento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Puesto)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Rfc)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Sueldo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdAdministrativoNavigation.IdPersona)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NumeroEmpleadoNavigation.IdEmpleado)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdAdministrativo">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.IdAdministrativo">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.IdAdministrativo">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
