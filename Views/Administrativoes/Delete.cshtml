@model SistemaCE.Models.Administrativo

@{
    ViewData["Title"] = "Eliminar Administrativo";
}
<link rel="stylesheet" href="~/css/delete_global.css" />
<div class="page-container">

    <div class="card-delete">

        <div class="title">Eliminar Administrativo</div>
        <div class="subtitle">Esta acción no se puede deshacer</div>

        <div class="warning-box">
            ⚠️ ¿Estás seguro de eliminar este registro?
        </div>

        <div class="grid">

            <div class="item">
                <div class="label">Departamento</div>
                <div class="value">@Model.Departamento</div>
            </div>

            <div class="item">
                <div class="label">Puesto</div>
                <div class="value">@Model.Puesto</div>
            </div>

            <div class="item">
                <div class="label">RFC</div>
                <div class="value">@Model.Rfc</div>
            </div>

            <div class="item">
                <div class="label">Sueldo</div>
                <div class="value">@Model.Sueldo</div>
            </div>

            <div class="item">
                <div class="label">Persona</div>
                <div class="value">
                    @Model.IdAdministrativoNavigation?.Nombre
                    @Model.IdAdministrativoNavigation?.ApellidoPaterno
                </div>
            </div>

            <div class="item">
                <div class="label">Empleado</div>
                <div class="value">
                    @Model.NumeroEmpleadoNavigation?.TipoEmpleado
                </div>
            </div>

        </div>

        <form asp-action="Delete" class="actions">
            <input type="hidden" asp-for="IdAdministrativo" />

            <a asp-action="Index" class="btn btn-back">← Cancelar</a>
            <input type="submit" value="Eliminar" class="btn btn-delete" />
        </form>

    </div>

</div>