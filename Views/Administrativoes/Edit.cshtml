@model SistemaCE.Models.Administrativo

@{
    ViewData["Title"] = "Editar Administrativo";
}

<link rel="stylesheet" href="~/css/edit_global.css" />
<div class="page-container">

    <div class="card-form">

        <div class="title">Editar Administrativo</div>
        <div class="subtitle">Modifica la información del registro</div>

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="IdAdministrativo" />

            @* <div class="form-group">
                <label>Empleado asignado</label>
                <select asp-for="NumeroEmpleado"
                        class="form-control"
                        asp-items="ViewBag.NumeroEmpleado">
                </select>
                <span asp-validation-for="NumeroEmpleado" class="text-danger"></span>
            </div> *@

            <div class="form-group">
                <label asp-for="Departamento"></label>
                <input asp-for="Departamento" />
                <span asp-validation-for="Departamento" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Puesto"></label>
                <input asp-for="Puesto" />
                <span asp-validation-for="Puesto" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Rfc"></label>
                <input asp-for="Rfc" />
                <span asp-validation-for="Rfc" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Sueldo"></label>
                <input asp-for="Sueldo" />
                <span asp-validation-for="Sueldo" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary">Guardar cambios</button>

        </form>

        <a asp-action="Index" class="back-link">← Volver al listado</a>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}