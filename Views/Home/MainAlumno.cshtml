
@{
    ViewData["Title"] = "MainAlumno";
    Layout = "_Layout";
}
<div class="flex flex-col h-full justify-evenly items-center">

    <!-- SALUDO -->
    <p class="text-3xl font-bold">
        ¡Hola! @User.Identity.Name
    </p>

    <!-- BLOQUE PRINCIPAL -->
    <div class="flex items-center gap-10">

        <!-- FOTO -->
        <img class="w-32 h-32 object-cover border" src="~/imagenes/foto_perfil.png" />

        <!-- DATOS -->
        <div class="space-y-2 text-lg">
            <p><span class="font-semibold">Nombre:</span> @User.Identity.Name</p>
            <p><span class="font-semibold">Apellido Paterno:</span> @User.FindFirst("ApellidoPaterno")?.Value</p>
            <p><span class="font-semibold">Apellido Materno:</span> @User.FindFirst("ApellidoMaterno")?.Value</p>
        </div>

    </div>

    <!-- GRUPO -->
    <div class="text-center">
        <p class="text-xl font-semibold">Grupo</p>
        <p class="text-lg text-blue-600">8IDS3</p>
    </div>

    <!-- ESTATUS -->
    <div class="text-center">
        <p class="text-xl font-semibold">Estatus</p>
        <p class="text-lg text-green-600">Activo</p>
    </div>

</div>

