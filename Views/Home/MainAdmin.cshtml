@using SistemaCE.Helpers
@model SistemaCE.Models.Administrativo
@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}
<div class="flex flex-col h-full justify-evenly items-center">

    <!-- SALUDO -->
    <p class="text-3xl font-bold">
        ¡Hola! @SessionHelper.GetName(User)
    </p>

    <!-- BLOQUE PRINCIPAL -->
    <div class="flex items-center gap-10">

        <!-- FOTO -->
        <img class="w-32 h-32 object-cover border" src="~/imagenes/foto_perfil.png" alt="Perfil" />
        <div class="space-y-2 text-lg">
            <p>
                <span class="font-semibold">Nombre:</span>
                @SessionHelper.GetName(User)
            </p>

            <p>
                <span class="font-semibold">Apellido Paterno:</span>
                @SessionHelper.GetValue(User, "ApellidoPaterno")
            </p>

            <p>
                <span class="font-semibold">Apellido Materno:</span>
                @SessionHelper.GetValue(User, "ApellidoMaterno")
            </p>
        </div>

    </div>
    <!-- ESTATUS -->
    <div class="text-center">
    </div>

</div>

